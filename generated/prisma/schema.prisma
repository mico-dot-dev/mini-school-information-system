generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model course {
  id          BigInt    @id @default(autoincrement())
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @db.Timestamptz(6)
  code        String
  name        String
  description String?
  grade       grade[]
  student     student[]
  subject     subject[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model grade {
  id                 BigInt    @id @default(autoincrement())
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  updated_at         DateTime? @db.Timestamptz(6)
  student_id         BigInt?
  subject_id         BigInt?
  course_id          BigInt?
  prelim             Decimal?  @db.Decimal
  midterm            Decimal?  @db.Decimal
  final              Decimal?  @db.Decimal
  final_grade        Decimal?  @db.Decimal
  remark             String?
  encoded_by_user_id BigInt?
  course             course?   @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user               user?     @relation(fields: [encoded_by_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  student            student?  @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subject            subject?  @relation(fields: [subject_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model student {
  id                  BigInt                @id(map: "students_pkey") @default(autoincrement())
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?             @db.Timestamptz(6)
  first_name          String
  last_name           String
  email               String?               @unique(map: "students_email_key")
  birth_date          DateTime              @db.Date
  course_id           BigInt
  grade               grade[]
  course              course                @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "students_course_id_fkey")
  subject_reservation subject_reservation[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model subject {
  id                                                                          BigInt                 @id @default(autoincrement())
  created_at                                                                  DateTime               @default(now()) @db.Timestamptz(6)
  code                                                                        String
  title                                                                       String
  units                                                                       Int                    @db.SmallInt
  updated_at                                                                  DateTime?              @db.Timestamptz(6)
  course_id                                                                   BigInt
  general_subject_id                                                          BigInt?
  grade                                                                       grade[]
  course                                                                      course                 @relation(fields: [course_id], references: [id], onDelete: Cascade)
  general_subject                                                             general_subject?       @relation(fields: [general_subject_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subject_prerequisite_subject_prerequisite_prerequisites_subject_idTosubject subject_prerequisite[] @relation("subject_prerequisite_prerequisites_subject_idTosubject")
  subject_prerequisite_subject_prerequisite_subject_idTosubject               subject_prerequisite[] @relation("subject_prerequisite_subject_idTosubject")
  subject_reservation                                                         subject_reservation[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model subject_prerequisite {
  id                                                             BigInt   @id(map: "subject_prerequisites_pkey") @default(autoincrement())
  created_at                                                     DateTime @default(now()) @db.Timestamptz(6)
  subject_id                                                     BigInt
  prerequisites_subject_id                                       BigInt
  subject_subject_prerequisite_prerequisites_subject_idTosubject subject  @relation("subject_prerequisite_prerequisites_subject_idTosubject", fields: [prerequisites_subject_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "subject_prerequisites_prerequisites_subject_id_fkey")
  subject_subject_prerequisite_subject_idTosubject               subject  @relation("subject_prerequisite_subject_idTosubject", fields: [subject_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "subject_prerequisites_subject_id_fkey")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model subject_reservation {
  id          BigInt    @id @default(autoincrement())
  student_id  BigInt
  subject_id  BigInt
  reserved_at DateTime? @db.Timestamptz(6)
  status      status
  student     student   @relation(fields: [student_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subject     subject   @relation(fields: [subject_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model user {
  id         BigInt    @id @default(autoincrement())
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  email      String    @unique
  role       String
  updated_at DateTime? @db.Timestamptz(6)
  grade      grade[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model general_subject {
  id         BigInt    @id @default(autoincrement())
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  title      String
  code       String
  units      Int       @db.SmallInt
  subject    subject[]
}

enum status {
  reserved
  cancelled
}
